# Backend runtime
FLASK_SECRET_KEY=replace-with-strong-random-value
JWT_SECRET_KEY=replace-with-strong-random-value

# Free tier (ephemeral): /tmp
# Paid persistent disk option on Render: /var/data/skillgenome.db
SKILLGENOME_DB_PATH=/tmp/skillgenome.db

# Comma-separated allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Optional GitHub API tuning
GITHUB_TOKEN=
GITHUB_PROJECT_LIMIT=10
GITHUB_LANGUAGE_CALL_LIMIT=0
